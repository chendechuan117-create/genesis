[Unit]
Description=Genesis V4 Knowledge Verifier Daemon
After=network.target

[Service]
Type=simple
WorkingDirectory=/home/chendechusn/Genesis/Genesis
EnvironmentFile=/home/chendechusn/Genesis/Genesis/.env
ExecStart=/home/chendechusn/Genesis/nanogenesis/venv/bin/python genesis/v4/verifier.py
Restart=always
RestartSec=3600

[Install]
WantedBy=default.target
