[Unit]
Description=Yogg — Genesis 放生模式 (standalone auto runner)
After=network-online.target v2raya.service
Wants=network-online.target

[Service]
Type=simple
User=yoga
WorkingDirectory=/home/yoga/Genesis
Environment=HF_HUB_OFFLINE=1
ExecStart=/usr/bin/proxychains4 -q /home/yoga/Genesis/venv/bin/python -u yogg_auto.py
Restart=always
RestartSec=30
StandardOutput=journal
StandardError=journal

# 内存保护：Yoga S730 只有 8GB
MemoryMax=3G
MemoryHigh=2G

[Install]
WantedBy=multi-user.target
